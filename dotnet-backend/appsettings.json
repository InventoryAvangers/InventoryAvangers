{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb+srv://username:password@cluster.mongodb.net/inventory-avengers",
    "DatabaseName": "inventory-avengers"
  },
  "Jwt": {
    "Secret": "your_super_secret_jwt_key_here",
    "ExpiresIn": "7d",
    "Issuer": "InventoryAvengers",
    "Audience": "InventoryAvengers"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "15m",
        "Limit": 500
      },
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "15m",
        "Limit": 20
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "15m",
        "Limit": 20
      },
      {
        "Endpoint": "POST:/api/auth/access-request",
        "Period": "15m",
        "Limit": 20
      }
    ]
  }
}
